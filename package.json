    "focus-trap-react": "^11.0.4",
    "framer-motion": "^10.16.16",
    "lucide-react": "^0.294.0",
    "next": "^14.2.30",
    "next-pwa": "^5.6.0",
    "openai": "^5.9.0",
    "postcss": "^8.4.32",
    "qrcode": "^1.5.4",
    "qrcode-generator": "^2.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.47.0",
    "recharts": "^2.15.4",
    "resend": "^6.6.0",
    "speakeasy": "^2.0.0",
    "stripe": "^18.3.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.3.6",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "eslint": "^8.53.0",
    "eslint-config-next": "14.0.3",
    "pg": "^8.16.3",
    "supabase": "^1.115.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
