{
  "name": "mindshifting",
  "version": "0.1.0",
  "private": true,
  "description": "A revolutionary AI-powered platform for mindset transformation and personal growth",
  "keywords": [
    "mindset",
    "personal-growth",
    "ai",
    "coaching",
    "transformation"
  ],
  "author": "MindShifting",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MyAiAd/MindShift.git"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/copy-vad-assets.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "supabase gen types typescript --project-id=YOUR_PROJECT_ID > types/supabase.ts",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "setup": "node scripts/setup-new-site.js",
    "setup:new": "node scripts/setup-new-site.js",
    "test": "npx playwright test --project=api-parity",
    "test:all": "npx playwright test",
    "test:parity": "npx playwright test tests/api/all-flows-parity.spec.ts",
    "test:problem": "npx playwright test tests/api/problem-shifting.spec.ts",
    "test:identity": "npx playwright test tests/api/identity-shifting.spec.ts",
    "test:belief": "npx playwright test tests/api/belief-shifting.spec.ts",
    "test:blockage": "npx playwright test tests/api/blockage-shifting.spec.ts",
    "test:reality": "npx playwright test tests/api/reality-shifting.spec.ts",
    "test:trauma": "npx playwright test tests/api/trauma-shifting.spec.ts",
    "test:digging": "npx playwright test tests/api/digging-deeper.spec.ts",
    "test:edge": "npx playwright test tests/api/edge-cases.spec.ts",
    "test:full-parity": "npx playwright test --project=full-parity",
    "test:v5": "npx playwright test tests/api/v5-all-flows.spec.ts",
    "test:v6": "npx playwright test tests/api/v2-v6-direct-parity.spec.ts",
    "test:v2-v6-parity": "tsx scripts/v2-v6-parity-check.ts",
    "test:v2-v6-route-parity": "npx playwright test tests/api/full-parity-report-v2-v6.spec.ts",
    "test:v2-v6-route-parity-local": "tsx scripts/v2-v6-route-parity-check.ts",
    "test:v9": "npx playwright test tests/api/v2-v9-direct-parity.spec.ts",
    "test:v2-v9-parity": "tsx scripts/v2-v9-parity-check.ts",
    "test:v2-v9-route-parity": "npx playwright test tests/api/v2-v9-parity.spec.ts",
    "ci:v9-gate": "tsx scripts/v2-v9-parity-check.ts",
    "ci:v9-theme-gate": "tsx scripts/v9-theme-token-gate.ts",
    "ci:v9-unit": "tsx --test tests/v9/resolver.test.ts tests/v9/preferences.test.ts tests/v9/theme-token-gate.test.ts tests/v9/session-parity.test.ts",
    "test:v9-visual": "SKIP_AUTH_SETUP=1 playwright test --project=v9-visual tests/v9/visual-regression.spec.ts",
    "test:v9-visual:update": "SKIP_AUTH_SETUP=1 playwright test --project=v9-visual tests/v9/visual-regression.spec.ts --update-snapshots",
    "test:v9-unit": "tsx --test tests/v9/resolver.test.ts tests/v9/preferences.test.ts tests/v9/theme-token-gate.test.ts tests/v9/session-parity.test.ts",
    "test:v7-speech-compliance": "npx tsx --test lib/voice/speech-compliance.test.ts",
    "test:v7-speech-route": "npx tsx --test tests/v7-speech-route.test.ts",
    "test:v7-stt-gates": "npx tsx --test tests/stt-hallucination-gates.test.ts",
    "test:v7-speech-corpus": "npx tsx --test tests/v7-speech-corpus-schema.test.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
